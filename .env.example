# ── Base de datos ─────────────────────────────────────────────────────────────
# En Railway: usar la URL de MongoDB Atlas o el plugin MongoDB de Railway
MONGODB_URI=mongodb://localhost:27017/mongo_tutor

# ── JWT ───────────────────────────────────────────────────────────────────────
# Usar valores largos y aleatorios en producción
JWT_SECRET=cambia_esto_por_una_clave_secreta_segura
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_secreta_segura
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────────────────
# Railway asigna PORT automáticamente — no cambiar este nombre
PORT=3001

# URL del frontend (puede ser múltiples separados por coma)
# Ejemplo Railway: https://mongotutor-frontend.up.railway.app
FRONTEND_URL=http://localhost:3000

# ── Playground (Atlas por estudiante) ────────────────────────────────────────
# Clave AES-256 para encriptar las URIs de Atlas de los estudiantes.
# Debe ser exactamente 64 caracteres hexadecimales (= 32 bytes).
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ATLAS_URI_ENCRYPTION_KEY=pon_aqui_64_caracteres_hex_generados_aleatoriamente_00000000000000

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production
